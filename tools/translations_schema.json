{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Article Translations Sidecar",
  "description": "Per-article translation status sidecar. Lives in the article folder as translations.json. Only languages with status: published are included in the site build.",
  "type": "object",
  "patternProperties": {
    "^(es|fr|de|nl|pt)$": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "published"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "reviewed_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string"
        },
        "source_chars": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
