{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Article Translations Sidecar",
  "description": "Per-article translation status sidecar. Lives in the article folder as translations.json. Only languages with status: published are included in the site build. Supports both human-reviewed and AI-QA-approved translations.",
  "type": "object",
  "patternProperties": {
    "^(es|fr|de|nl|pt)$": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["draft", "published"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "reviewed_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reviewer": {
          "type": "string",
          "minLength": 1
        },
        "approval_method": {
          "type": "string",
          "enum": ["human", "ai_qa"]
        },
        "ai_generated": {
          "type": "boolean"
        },
        "quality_checked_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "quality_check_model": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "source_chars": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
