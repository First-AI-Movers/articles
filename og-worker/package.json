{
  "name": "faim-og-worker",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8788",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "build": "wrangler deploy --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "bundle-size": "wrangler deploy --dry-run --outdir=dist && echo '--- Raw size ---' && du -sh dist"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "^2.6.2",
    "hono": "^4.8.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "@cloudflare/workers-types": "^4.20260426.1",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.86.0"
  }
}
