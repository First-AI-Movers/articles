<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script>
(function() {
  var stored = localStorage.getItem('theme');
  if (stored === 'light' || stored === 'dark') {
    document.documentElement.setAttribute('data-theme', stored);
  }
})();
</script>
<title>{% block title %}{{ site_title }}{% endblock %}</title>
<meta name="description" content="{% block description %}{{ site_description }}{% endblock %}">
<meta name="robots" content="{% block robots %}index, follow{% endblock %}">
{% block canonical %}<link rel="canonical" href="{{ site_url }}{{ page_path }}">{% endblock %}
<link rel="stylesheet" href="{{ rel_root }}style.css">
{% block head_extra %}{% endblock %}
</head>
<body>
<a href="#main-content" class="skip-link">Skip to content</a>
<header class="site">
  <a class="brand" href="{{ rel_root }}">{{ site_title }}</a>
  <nav aria-label="Primary">
    <a href="{{ rel_root }}">Home</a>
    <a href="{{ rel_root }}topics/">Topics</a>
    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle light mode" aria-pressed="false" type="button">Light mode</button>
  </nav>
</header>

<main id="main-content" tabindex="-1"{% block main_class %}{% endblock %}>
{% block content %}{% endblock %}
</main>

<footer class="site">
  <div class="row">
    <span>Archive of <a href="{{ publisher_url }}">{{ publisher_name }}</a> by <a href="{{ author_url }}">{{ author_name }}</a></span>
  </div>
</footer>
<script>
(function() {
  var toggle = document.getElementById('theme-toggle');
  if (!toggle) return;
  function updateState() {
    var current = document.documentElement.getAttribute('data-theme') || 'dark';
    var isDark = current === 'dark';
    toggle.textContent = isDark ? 'Light mode' : 'Dark mode';
    toggle.setAttribute('aria-label', isDark ? 'Toggle light mode' : 'Toggle dark mode');
    toggle.setAttribute('aria-pressed', String(!isDark));
  }
  updateState();
  toggle.addEventListener('click', function() {
    var current = document.documentElement.getAttribute('data-theme') || 'dark';
    var next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateState();
  });
})();
</script>
{% block scripts %}{% endblock %}
</body>
</html>
