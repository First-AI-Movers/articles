{% extends "base.html.j2" %}
{% block title %}First AI Movers — Article Archive{% endblock %}
{% block description %}Open-access archive of {{ stats.total }} original articles by Dr. Hernani Costa on AI strategy, EU AI Act compliance, AI governance, and agentic systems for European SMEs. Published {{ stats.date_min_month }}–{{ stats.date_max_month }}.{% endblock %}
{% block main_class %} class="wide"{% endblock %}

{% block head_extra %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "First AI Movers — Article Archive",
  "url": "{{ site_url }}",
  "description": "{{ self.description() }}",
  "author": {
    "@type": "Person",
    "name": "Dr. Hernani Costa",
    "url": "https://drhernanicosta.com",
    "sameAs": ["https://orcid.org/0000-0002-6813-4641"]
  },
  "publisher": {
    "@type": "Organization",
    "name": "First AI Movers",
    "url": "https://firstaimovers.com"
  },
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "inLanguage": "en",
  "datePublished": "{{ stats.date_min }}",
  "dateModified": "{{ stats.date_max }}"
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "First AI Movers",
  "url": "https://firstaimovers.com",
  "sameAs": [
    "https://www.linkedin.com/newsletters/first-ai-movers-7285707335191154688/",
    "https://dev.to/dr_hernani_costa",
    "https://medium.com/@firstaimovers",
    "https://open.spotify.com/show/5HX1cZF7Ojikm2VWcAzTnt",
    "https://youtube.com/@DrHernaniCosta"
  ],
  "founder": {
    "@type": "Person",
    "name": "Dr. Hernani Costa",
    "url": "https://drhernanicosta.com"
  }
}
</script>
{% endblock %}

{% block content %}
<h1>First AI Movers — Article Archive</h1>

<p class="lede">{{ stats.total }} original articles by <a href="https://drhernanicosta.com">Dr. Hernani Costa</a>, PhD, on AI strategy, EU AI Act compliance, governance, and agentic systems for European businesses. Published under CC BY 4.0 — free to read, cite, adapt, and redistribute with attribution.</p>

<div class="search-box">
  <label for="archive-search" class="visually-hidden">Search articles</label>
  <input type="search" id="archive-search" placeholder="Search articles by title, topic, or tag…" aria-label="Search articles">
  <div id="search-results" class="search-results" aria-live="polite"></div>
</div>

<div class="stats">
  <div><b>{{ stats.total }}</b><span>articles</span></div>
  <div><b>{{ stats.topics_count }}</b><span>canonical topics</span></div>
  <div><b>{{ stats.date_min_month }}</b><span>first article</span></div>
  <div><b>{{ stats.date_max_month }}</b><span>most recent</span></div>
</div>

<h2>Latest articles</h2>
{% for article in latest %}
  {% include "partials/article_card.html.j2" %}
{% endfor %}

<p class="browse-all"><a href="{{ rel_root }}topics/">Browse all {{ topics_with_page|length }} topic pages →</a></p>

<div class="data-links">
  <h3>Machine-readable surfaces</h3>
  <ul>
    <li><code>/index.json</code> — catalog of all {{ stats.total }} articles with metadata</li>
    <li><code>/feed.xml</code> — Atom feed of the 50 most-recent articles</li>
    <li><code>/feed.json</code> — JSON Feed 1.1 of the 50 most-recent articles</li>
    <li><code>/llms.txt</code> — LLM discovery summary</li>
    <li><code>/llms-full.txt</code> — full-text corpus for bulk LLM ingestion ({{ stats.total }} articles, ~7 MB)</li>
    <li><code>/llms-recent.txt</code> — rolling 30-day window for small-context LLM ingestion</li>
    <li><code>/sitemap.xml</code> — XML sitemap pointing to canonical article URLs</li>
    <li><code>/hernanicosta.json</code> — Schema.org Person entity for the author</li>
  </ul>
</div>
{% endblock %}

{% block scripts %}
<script src="{{ rel_root }}search.js"></script>
{% endblock %}
