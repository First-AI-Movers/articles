{% extends "base.html.j2" %}
{% block title %}{{ topic }} Articles — First AI Movers Archive{% endblock %}
{% block description %}{% if topic_intro and topic_intro.lede %}{{ topic_intro.lede }}{% else %}{{ articles|length }} original articles on {{ topic }} by Dr. Hernani Costa, PhD. Practitioner analysis and strategic frameworks for European SMEs, published via First AI Movers.{% endif %}{% endblock %}
{% block og_type %}website{% endblock %}
{% block og_image %}{% if og_config and og_config.enabled %}{% set topic_slug_val = topic_slug(topic) %}{% set og_params = {"title": topic} %}<meta property="og:image" content="{{ og_config.base_url }}/topic/{{ topic_slug_val }}.png?v={{ og_config.version }}&{{ og_params|urlencode }}"><meta property="og:image:width" content="1200"><meta property="og:image:height" content="630">{% endif %}{% endblock %}
{% block twitter_card %}{% if og_config and og_config.enabled %}summary_large_image{% else %}summary{% endif %}{% endblock %}
{% block head_extra %}
<meta name="article:author" content="https://drhernanicosta.com">
<meta name="article:published_time" content="{{ articles[-1].published_date }}T00:00:00Z">
<meta name="article:modified_time" content="{{ articles[0].published_date }}T00:00:00Z">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "{{ topic }}",
  "description": "{{ self.description() }}",
  "url": "{{ site_url }}{{ page_path }}",
  "inLanguage": "en",
  "datePublished": "{{ articles[-1].published_date }}",
  "dateModified": "{{ articles[0].published_date }}",
  "isPartOf": {"@type": "WebSite", "name": "First AI Movers — Article Archive", "url": "{{ site_url }}"},
  "author": {"@type": "Person", "name": "Dr. Hernani Costa", "url": "https://drhernanicosta.com", "sameAs": ["https://orcid.org/0000-0002-6813-4641"]},
  "publisher": {"@type": "Organization", "name": "First AI Movers", "url": "https://firstaimovers.com"},
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "about": {"@type": "Thing", "name": "{{ topic }}"},
  "mainEntityOfPage": {"@type": "WebPage", "@id": "{{ site_url }}{{ page_path }}"},
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": {{ articles|length }},
    "itemListElement": [
      {% for a in articles[:20] %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "url": "{{ a.canonical_url }}",
        "name": {{ a.title|tojson }}
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site_url }}/"},
    {"@type": "ListItem", "position": 2, "name": "Topics", "item": "{{ site_url }}/topics/"},
    {"@type": "ListItem", "position": 3, "name": {{ topic|tojson }}, "item": "{{ site_url }}{{ page_path }}"}
  ]
}
</script>
{% endblock %}

{% block content %}
<nav class="breadcrumb" aria-label="Breadcrumb"><a href="{{ rel_root }}">Home</a> / <a href="{{ rel_root }}topics/">Topics</a> / {{ topic }}</nav>

<h1>{{ topic }}</h1>
<p class="meta">{{ articles|length }} articles · Latest: {{ articles[0].published_date }}</p>

{% if topic_intro and topic_intro.lede %}
<p class="lede">{{ topic_intro.lede }}</p>
{% else %}
<p class="lede">Every article in the First AI Movers archive tagged <strong>{{ topic }}</strong>. Each article's canonical home is on its publishing property — Radar, the newsletter, Insights, Voices, or a third-party platform — linked from each title below.</p>
{% endif %}

{% if topic_intro and (topic_intro.key_themes or topic_intro.why_it_matters) %}
<section class="topic-intro" aria-label="About this topic">
  {% if topic_intro.key_themes %}
  <h2>Key themes</h2>
  <ul class="key-themes">
    {% for theme in topic_intro.key_themes %}<li>{{ theme }}</li>{% endfor %}
  </ul>
  {% endif %}
  {% if topic_intro.why_it_matters %}
  <h2>Why it matters</h2>
  <p>{{ topic_intro.why_it_matters }}</p>
  {% endif %}
</section>
{% endif %}

<h2 class="articles-heading">Articles ({{ articles|length }})</h2>
{% for article in articles %}
  {% include "partials/article_card.html.j2" %}
{% endfor %}

{% if series_in_topic %}
<section class="series-in-topic" aria-label="Series in this topic">
  <h2>Series in this topic</h2>
  {% for s in series_in_topic %}
  <article class="series-card" id="series-{{ s.slug }}">
    <h3><a href="{{ rel_root }}articles/{{ s.first_article.slug }}/">{{ s.title }}</a></h3>
    <p class="series-meta">{{ s.article_count }} articles</p>
    <p class="series-description">{{ s.description }}</p>
  </article>
  {% endfor %}
</section>
{% endif %}

{% if quick_reads %}
<section class="quick-reads" aria-label="Quick reads">
  <h2>Quick reads</h2>
  {% for qr in quick_reads %}
  <article class="quick-read">
    <h3><a href="{{ qr.canonical_url }}" rel="noopener">{{ qr.title }}</a></h3>
    <p class="quick-read-meta">{{ qr.published_date }}</p>
    <p class="quick-read-tldr">{{ qr.tldr }}</p>
  </article>
  {% endfor %}
</section>
{% endif %}

{% if related_topics %}
<h2>Related topics</h2>
<p class="related-topic-list">
{% for rt in related_topics %}{% if rt in topics_with_page %}<a href="{{ rel_root }}topics/{{ topic_slug(rt) }}/">{{ rt }}</a>{% if not loop.last %}<span class="sep" aria-hidden="true"> · </span>{% endif %}{% endif %}{% endfor %}
</p>
{% endif %}
{% endblock %}
