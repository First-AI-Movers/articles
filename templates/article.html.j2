{% extends "base.html.j2" %}
{% block robots %}<meta name="robots" content="noindex, follow">{% endblock %}
{% block canonical %}<link rel="canonical" href="{{ canonical_url }}">{% endblock %}
{% block title %}{{ title }} — First AI Movers Archive{% endblock %}
{% block description %}{{ summary or site_description }}{% endblock %}
{% block og_type %}article{% endblock %}
{% block head_extra %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title|tojson }},
  "datePublished": "{{ published_date }}",
  "dateModified": "{{ published_date }}",
  "author": {
    "@type": "Person",
    "name": "Dr. Hernani Costa",
    "url": "https://drhernanicosta.com",
    "sameAs": ["https://orcid.org/0000-0002-6813-4641"]
  },
  "publisher": {
    "@type": "Organization",
    "name": "First AI Movers",
    "url": "https://firstaimovers.com"
  },
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "{{ canonical_url }}",
  "isBasedOn": "{{ canonical_url }}",
  "inLanguage": "en",
  "articleSection": {{ (topics|list)|tojson }}
}
</script>
{% endblock %}

{% block content %}
<article class="article-page">
  <header class="article-header">
    <p class="archive-notice">Archive copy — <a href="{{ canonical_url }}" rel="noopener">read original at {{ canonical_host_label }}</a></p>
    <h1>{{ title }}</h1>
    <p class="meta">{{ published_date }} · {{ author }} · Published on {{ canonical_host_label }}</p>
    {% if topics %}
    <div class="topics">
      {% for t in topics %}{% if t in topics_with_page %}<a href="{{ rel_root }}topics/{{ topic_slug(t) }}/">{{ t }}</a>{% else %}<span>{{ t }}</span>{% endif %}{% endfor %}
    </div>
    {% endif %}
  </header>

  <div class="article-body">
    {{ body_html|safe }}
  </div>

  <footer class="article-footer">
    <p>Originally published on <a href="{{ canonical_url }}" rel="noopener">{{ canonical_host_label }}</a> · {{ published_date }}</p>
    <p>Licensed under <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a> · Archive maintained by <a href="https://firstaimovers.com">First AI Movers</a></p>
  </footer>
</article>
{% endblock %}
