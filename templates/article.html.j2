{% extends "base.html.j2" %}
{% block robots %}{% if lang and lang != 'en' %}<meta name="robots" content="index, follow">{% else %}<meta name="robots" content="noindex, follow">{% endif %}{% endblock %}
{% block canonical %}{% if lang and lang != 'en' %}<link rel="canonical" href="{{ site_url }}{{ page_path }}">{% else %}<link rel="canonical" href="{{ canonical_url }}">{% endif %}{% endblock %}
{% block hreflang %}{% if translations %}
<link rel="alternate" hreflang="en" href="{{ site_url }}/articles/{{ slug }}/" />
{% for lang_code, t in translations.items() %}
<link rel="alternate" hreflang="{{ lang_code }}" href="{{ site_url }}/{{ lang_code }}/articles/{{ slug }}/" />
{% endfor %}
<link rel="alternate" hreflang="x-default" href="{{ site_url }}/articles/{{ slug }}/" />
{% endif %}{% endblock %}
{% block title %}{{ title }} — First AI Movers Archive{% endblock %}
{% block description %}{{ summary or site_description }}{% endblock %}
{% block og_type %}article{% endblock %}
{% block og_image %}{% if og_config and og_config.enabled %}{% set og_params = {"title": title, "topic": topics[0] if topics else None, "date": published_date, "author": author} %}<meta property="og:image" content="{{ og_config.base_url }}/article/{{ folder }}.png?v={{ og_config.version }}&{{ og_params|urlencode }}"><meta property="og:image:width" content="1200"><meta property="og:image:height" content="630">{% endif %}{% endblock %}
{% block twitter_card %}{% if og_config and og_config.enabled %}summary_large_image{% else %}summary{% endif %}{% endblock %}
{% block head_extra %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title|tojson }},
  "datePublished": "{{ published_date }}",
  "dateModified": "{{ published_date }}",
  "author": {
    "@type": "Person",
    "name": "Dr. Hernani Costa",
    "url": "https://drhernanicosta.com",
    "sameAs": ["https://orcid.org/0000-0002-6813-4641"]
  },
  "publisher": {
    "@type": "Organization",
    "name": "First AI Movers",
    "url": "https://firstaimovers.com"
  },
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "url": "{{ canonical_url }}",
  "isBasedOn": "{{ canonical_url }}",
  "inLanguage": {{ (lang or 'en')|tojson }}{% if summary_short %},
  "description": {{ summary_short|tojson }}{% elif summary %},
  "description": {{ summary|tojson }}{% endif %},
  "articleSection": {{ (topics|list)|tojson }}{% if doi %},
  "identifier": {
    "@type": "PropertyValue",
    "propertyID": "DOI",
    "value": "{{ doi }}"
  },
  "sameAs": "https://doi.org/{{ doi }}"{% endif %}{% if series %},
  "isPartOf": {
    "@type": "CreativeWorkSeries",
    "name": {{ series.title|tojson }},
    "url": "{{ site_url }}/topics/{{ topic_slug(topics[0]) if topics else '' }}/#series-{{ series.slug }}"
  }{% endif %}{% if outgoing_citations %},
  "citation": [
    {% for c in outgoing_citations %}
    {
      "@type": "CreativeWork",
      "name": {{ c.title|tojson }},
      "url": "{{ site_url }}{{ c.local_url }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]{% endif %}
}
</script>
{% endblock %}

{% block content %}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <a href="{{ rel_root }}">Home</a>
  {% if topics %}
  / <a href="{{ rel_root }}topics/">Topics</a>
  / <a href="{{ rel_root }}topics/{{ topic_slug(topics[0]) }}/">{{ topics[0] }}</a>
  {% endif %}
  / {{ title }}
</nav>

<article class="article-page">
  <header class="article-header">
    <p class="archive-notice">Archive copy — <a href="{{ canonical_url }}" rel="noopener">read original at {{ canonical_host_label }}</a></p>
    {% if lang and lang != 'en' and translations and translations.get(lang) and translations[lang].get('ai_generated') %}
    <p class="ai-translation-notice" role="note">
      This page is an AI-generated translation of the original English article by Dr. Hernani Costa / First AI Movers.
      The <a href="{{ canonical_url }}" rel="noopener">English version</a> is the authoritative source.
      Translation quality is checked automatically, but nuances may differ.
    </p>
    {% endif %}
    <h1>{{ title }}</h1>
    <p class="meta">{{ published_date }} · {{ author }} · Published on {{ canonical_host_label }} · {{ reading_time }} min read</p>
    {% if series %}
    <p class="series-chip" aria-label="Series">
      Part {{ series.order }} of {{ series.total }} in <strong>{{ series.title }}</strong>
    </p>
    {% endif %}
    {% if topics %}
    <div class="topics">
      {% for t in topics %}{% if t in topics_with_page %}<a href="{{ rel_root }}topics/{{ topic_slug(t) }}/">{{ t }}</a>{% else %}<span>{{ t }}</span>{% endif %}{% endfor %}
    </div>
    {% endif %}
  </header>

  {% if toc_headings|length >= 2 %}
  <nav class="toc" aria-label="Table of contents">
    <h2>Table of contents</h2>
    <ul>
      {% for h in toc_headings %}
      <li class="toc-level-{{ h.level }}"><a href="#{{ h.id }}">{{ h.text }}</a></li>
      {% endfor %}
    </ul>
  </nav>
  {% endif %}

  <div class="article-body">
    {{ body_html|safe }}
  </div>

  {% if related_articles %}
  <section class="related-articles" aria-label="Related articles">
    <h2>Related articles</h2>
    {% for ra in related_articles %}
    <article class="related-article">
      <h3><a href="{{ rel_root }}articles/{{ ra.slug }}/">{{ ra.title }}</a></h3>
      <p class="related-meta">{{ ra.published_date }} · {{ ra.canonical_host_label }}</p>
    </article>
    {% endfor %}
    {% if topics and topics[0] in topics_with_page %}
    <p class="explore-topic"><a href="{{ rel_root }}topics/{{ topic_slug(topics[0]) }}/">Explore all {{ topics[0] }} articles →</a></p>
    {% endif %}
  </section>
  {% endif %}

  {% if series %}
  <nav class="series-nav" aria-label="Series navigation">
    {% if series.prev %}
    <a class="series-prev" href="{{ rel_root }}articles/{{ series.prev.slug }}/">← Previous in series: {{ series.prev.title }}</a>
    {% endif %}
    {% if series.next %}
    <a class="series-next" href="{{ rel_root }}articles/{{ series.next.slug }}/">Continue reading → {{ series.next.title }}</a>
    {% endif %}
  </nav>
  {% endif %}

  {% if errata_entries %}
  <aside class="errata" aria-label="Corrections and editorial notes">
    <h2>Corrections and editorial notes</h2>
    {% for e in errata_entries %}
    <div class="erratum">
      <h3>{{ e.title }}</h3>
      <p class="erratum-meta">
        <span class="erratum-date">{{ e.date }}</span>
        <span class="erratum-type">{{ e.type.replace('-', ' ').title() }}</span>
        <span class="erratum-editor">Editor: {{ e.editor }}</span>
      </p>
      <div class="erratum-body">
        {{ e.body|markdown|safe }}
      </div>
    </div>
    {% endfor %}
  </aside>
  {% endif %}

  {% if doi %}
  <section class="cite-block" aria-label="Cite this article">
    <h2>Cite this article</h2>
    <p class="doi-line">DOI: <a href="https://doi.org/{{ doi }}" rel="noopener">https://doi.org/{{ doi }}</a></p>

    <details class="cite-format">
      <summary>APA</summary>
      <pre>{{ citation_apa }}</pre>
    </details>

    <details class="cite-format">
      <summary>BibTeX</summary>
      <pre>{{ citation_bibtex }}</pre>
    </details>

    <details class="cite-format">
      <summary>CSL JSON</summary>
      <pre>{{ citation_csl_json }}</pre>
    </details>
  </section>
  {% endif %}

  {% if outgoing_citations %}
  <section class="citation-section" aria-label="References in this archive">
    <h2>References in this archive</h2>
    <ul class="citation-list">
      {% for c in outgoing_citations %}
      <li>
        <a href="{{ rel_root }}articles/{{ c.slug }}/">{{ c.title }}</a>
        <span class="citation-meta">{{ c.published_date }}</span>
      </li>
      {% endfor %}
    </ul>
    {% if outgoing_citations_truncated %}
    <p class="citation-truncated">Showing first {{ outgoing_citations|length }}.</p>
    {% endif %}
  </section>
  {% endif %}

  {% if incoming_citations %}
  <section class="citation-section" aria-label="Referenced by">
    <h2>Referenced by</h2>
    <ul class="citation-list">
      {% for c in incoming_citations %}
      <li>
        <a href="{{ rel_root }}articles/{{ c.slug }}/">{{ c.title }}</a>
        <span class="citation-meta">{{ c.published_date }}</span>
      </li>
      {% endfor %}
    </ul>
    {% if incoming_citations_truncated %}
    <p class="citation-truncated">Showing first {{ incoming_citations|length }}.</p>
    {% endif %}
  </section>
  {% endif %}

  <footer class="article-footer">
    <p>Originally published on <a href="{{ canonical_url }}" rel="noopener">{{ canonical_host_label }}</a> · {{ published_date }}</p>
    <p>Licensed under <a href="https://creativecommons.org/licenses/by/4.0/">CC BY 4.0</a> · Archive maintained by <a href="https://firstaimovers.com">First AI Movers</a></p>
  </footer>
  {% include "partials/giscus.html.j2" %}
</article>
{% endblock %}
