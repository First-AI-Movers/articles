# GitHub Personal Access Token with repo scope
# Required for rebuild_index.py to read article metadata and push index.json
GITHUB_TOKEN=ghp_your_token_here

# 1Password secret reference for LLM API key (used by add_tldr.py)
# Format: op://vault-name/item-name/field-name
# OP_ITEM_REF=op://your-vault/your-item/your-field
