# GitHub Personal Access Token with repo scope
# Required for rebuild_index.py to read article metadata and push index.json
GITHUB_TOKEN=ghp_your_token_here

# OpenRouter API key (for add_tldr.py TL;DR generation)
# Optional — if not set, the script fetches from 1Password automatically:
#   vault: publicinnovation-infra, item: radar-engine, field: openrouter_api_key
# OPENAI_API_KEY=sk-or-your_key_here
