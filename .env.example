# GitHub Personal Access Token with repo scope.
# Required for add_tldr.py to fetch articles and push updates via the
# GitHub Contents API. The index/sitemap/feed/corpus rebuild runs in CI
# against the working tree and does not need this token.
GITHUB_TOKEN=ghp_your_token_here

# OpenAI API key for add_tldr.py (used to generate missing TL;DR sections).
# Either set directly here, or leave blank and point OP_ITEM_REF at a
# 1Password secret that holds the key.
OPENAI_API_KEY=sk-your-key-here

# 1Password secret reference fallback for the OpenAI key (used by add_tldr.py).
# Format: op://vault-name/item-name/field-name
# OP_ITEM_REF=op://your-vault/your-item/your-field
